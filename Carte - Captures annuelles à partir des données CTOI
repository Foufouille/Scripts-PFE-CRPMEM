  header = TRUE, sep = ","
)

iotc_grid_to_coords <- function(codes) {
  codes <- as.character(codes)
  out <- tibble(code = codes) %>%
    mutate(
      size_code = str_sub(code, 1, 1),
      quad_code = str_sub(code, 2, 2),
      lat_code  = as.numeric(str_sub(code, 3, 4)),
      lon_code  = as.numeric(str_sub(code, 5, 7)),
      cell_size = case_when(
        size_code == "5" ~ 1,
        size_code == "6" ~ 5,
        TRUE ~ NA_real_
      ),
      lat_min = case_when(
        quad_code == "1" ~  lat_code,
        quad_code == "2" ~ -(lat_code + cell_size),
        quad_code == "3" ~ -(lat_code + cell_size),
        quad_code == "4" ~  lat_code,
        TRUE ~ NA_real_
      ),
      lon_min = case_when(
        quad_code %in% c("1", "2") ~  lon_code,
        quad_code %in% c("3", "4") ~ -lon_code,
        TRUE ~ NA_real_
      )
    )
  out
}

# =========================================================
# 1. NETTOYAGE & AGRÉGATION EN MAILLES
# =========================================================

coords <- iotc_grid_to_coords(iotc_raw$FISHING_GROUND_CODE)

data_clean <- iotc_raw %>%
  mutate(
    espece     = str_trim(toupper(as.character(SPECIES_CODE))),
    catch_t    = as.numeric(CATCH),
    Annee      = as.integer(YEAR),
    lat_maille = coords$lat_min,
    lon_maille = coords$lon_min
  ) %>%
  filter(
    FLEET_CODE == "EUREU",
    FISHERY_CODE == "LLO",
    !FISHING_GROUND_CODE %in% c(9000020, 9200020),
    espece %in% c("YFT", "BET", "SWO", "SKJ"),
    !is.na(lat_maille), !is.na(lon_maille), !is.na(catch_t)
  ) %>%
  group_by(Annee, espece, lat_maille, lon_maille) %>%
  summarise(
    catch = sum(catch_t, na.rm = TRUE),
    .groups = "drop"
  )

